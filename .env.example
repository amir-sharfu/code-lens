# CodeLens environment variables — example / template
# Copy this file to .env and fill in real values.
# NEVER commit real keys — .env is gitignored.

# Phase 3 — Embeddings & Vector Store
# No API key needed for the default local backend (sentence-transformers).
# Override the default embedding model if desired:
# CODELENS_EMBED_MODEL=all-MiniLM-L6-v2

# ChromaDB persist directory (default: .codelens/chroma)
# CODELENS_CHROMA_DIR=.codelens/chroma

# Optional: use OpenAI embeddings instead of local model
# CODELENS_EMBEDDING_BACKEND=openai
# OPENAI_API_KEY=<your-openai-api-key-here>

# Optional: Anthropic API key (for future answer-generation features)
# ANTHROPIC_API_KEY=<your-anthropic-api-key-here>
